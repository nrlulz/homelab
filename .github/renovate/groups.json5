{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "packageRules": [
    {
      // group kubernetes updates
      "matchPackageNames": [
        "docker.io/kindest/node",
        "ghcr.io/siderolabs/kubelet"
      ],
      "groupName": "kubernetes",
      "minimumGroupSize": 2
    },
    {
      // group actual and actual-helpers updates
      "matchPackageNames": [
        "ghcr.io/actualbudget/actual",
        "ghcr.io/psybers/actual-helpers"
      ],
      "groupName": "actual",
      "minimumGroupSize": 2
    },
    {
      // group intel-device-plugins updates
      "matchPackageNames": [
        "intel-device-plugins-gpu",
        "intel-device-plugins-operator"
      ],
      "groupName": "intel-device-plugins",
      "minimumGroupSize": 2
    },
    {
      // group immich updates
      "matchPackageNames": [
        "ghcr.io/immich-app/immich-machine-learning",
        "ghcr.io/immich-app/immich-server"
      ],
      "groupName": "immich",
      "minimumGroupSize": 2
    }
  ]
}
